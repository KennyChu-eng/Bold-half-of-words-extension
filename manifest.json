{
  "manifest_version": 3,
  "name": "Bionic Font",
  "version": "1.0",
  "description": "Chrome extension to apply bionic reading font to web pages.",
  "permissions": ["activeTab","storage"],
  "action": {
    "default_popup": "popup.html"
  },
    "content_scripts": [
        {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_idle"
        }
    ]
}